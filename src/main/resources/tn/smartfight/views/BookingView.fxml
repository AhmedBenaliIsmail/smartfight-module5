<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>
<VBox xmlns:fx="http://javafx.com/fxml/1" xmlns="http://javafx.com/javafx/21"
      fx:controller="tn.smartfight.controllers.BookingController"
      stylesheets="@../styles/smartfight.css"
      style="-fx-background-color: #080808;"
      spacing="0">

    <!-- Header -->
    <HBox styleClass="page-header" alignment="CENTER_LEFT" spacing="16">
        <VBox spacing="4">
            <Label text="BOOKINGS" styleClass="page-title"/>
            <Label text="Reserve your tickets for upcoming events" styleClass="page-subtitle"/>
        </VBox>
    </HBox>

    <TabPane fx:id="bookingTabs" styleClass="dark-tab-pane" VBox.vgrow="ALWAYS">

        <!-- TAB 1: Book Tickets -->
        <Tab text="BOOK TICKETS" closable="false">
            <HBox style="-fx-padding: 32 40 32 40;" spacing="48" alignment="TOP_LEFT">

                <!-- Booking Form -->
                <VBox styleClass="card" spacing="18" minWidth="380" maxWidth="420">
                    <HBox styleClass="section-header" alignment="CENTER_LEFT">
                        <Label text="SELECT EVENT" styleClass="section-header-label"/>
                    </HBox>
                    <ComboBox fx:id="cbEvent" styleClass="dark-combo" maxWidth="Infinity" promptText="Choose an event..."/>
                    <Label fx:id="lblCapacity" text="Select an event to see availability"
                           style="-fx-text-fill: #555555; -fx-font-size: 12px; -fx-font-weight: bold;"/>

                    <Region style="-fx-background-color: #1a1a1a; -fx-pref-height: 1; -fx-min-height: 1;"/>

                    <HBox styleClass="section-header" alignment="CENTER_LEFT">
                        <Label text="TICKET TYPE" styleClass="section-header-label"/>
                    </HBox>
                    <ComboBox fx:id="cbTicketType" styleClass="dark-combo" maxWidth="Infinity"/>
                    <Label fx:id="lblPrice" text="" styleClass="label-meta"/>

                    <HBox styleClass="section-header" alignment="CENTER_LEFT">
                        <Label text="QUANTITY (MAX 4)" styleClass="section-header-label"/>
                    </HBox>
                    <Spinner fx:id="spnQuantity" styleClass="dark-spinner" maxWidth="140"/>

                    <Region style="-fx-background-color: #1a1a1a; -fx-pref-height: 1; -fx-min-height: 1;"/>

                    <Label fx:id="lblTotal" text="" styleClass="stat-value"/>

                    <Button text="CONFIRM BOOKING" styleClass="btn-primary"
                            onAction="#onConfirmBooking" maxWidth="Infinity"
                            style="-fx-font-size: 13px; -fx-padding: 14 0;"/>

                    <Label fx:id="lblMessage" text="" wrapText="true"
                           style="-fx-text-fill: #c9a227; -fx-font-size: 13px; -fx-font-weight: bold;"/>
                </VBox>

                <!-- Pricing Info -->
                <VBox styleClass="card" spacing="16" minWidth="240">
                    <HBox styleClass="section-header" alignment="CENTER_LEFT">
                        <Label text="TICKET PRICING" styleClass="section-header-label"/>
                    </HBox>
                    <VBox spacing="12">
                        <HBox spacing="0" alignment="CENTER_LEFT">
                            <Label text="VIP"
                                   style="-fx-text-fill:#c9a227; -fx-font-weight:bold; -fx-font-size:12px;" minWidth="110"/>
                            <Label text="50.00 TND"
                                   style="-fx-text-fill:#ffffff; -fx-font-size:13px; -fx-font-weight:bold;"/>
                        </HBox>
                        <HBox spacing="0" alignment="CENTER_LEFT">
                            <Label text="REGULAR"
                                   style="-fx-text-fill:#aaaaaa; -fx-font-weight:bold; -fx-font-size:12px;" minWidth="110"/>
                            <Label text="25.00 TND"
                                   style="-fx-text-fill:#ffffff; -fx-font-size:13px; -fx-font-weight:bold;"/>
                        </HBox>
                        <HBox spacing="0" alignment="CENTER_LEFT">
                            <Label text="STANDING"
                                   style="-fx-text-fill:#666666; -fx-font-weight:bold; -fx-font-size:12px;" minWidth="110"/>
                            <Label text="10.00 TND"
                                   style="-fx-text-fill:#ffffff; -fx-font-size:13px; -fx-font-weight:bold;"/>
                        </HBox>
                    </VBox>
                    <Region style="-fx-background-color: #1a1a1a; -fx-pref-height: 1; -fx-min-height: 1;"/>
                    <Label text="A QR code will be generated after successful booking."
                           style="-fx-text-fill:#444444; -fx-font-size:12px;" wrapText="true"/>
                </VBox>

            </HBox>
        </Tab>

        <!-- TAB 2: My Bookings -->
        <Tab text="MY BOOKINGS" closable="false">
            <VBox style="-fx-padding: 28 32 32 32;" spacing="16">
                <HBox styleClass="section-header" alignment="CENTER_LEFT">
                    <Label text="BOOKING HISTORY" styleClass="section-header-label"/>
                </HBox>
                <TableView fx:id="bookingsTable" styleClass="dark-table" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colEvent"   text="EVENT"     />
                        <TableColumn fx:id="colDate"    text="DATE"      />
                        <TableColumn fx:id="colType"    text="TYPE"      />
                        <TableColumn fx:id="colQty"     text="QTY"       />
                        <TableColumn fx:id="colPrice"   text="TOTAL"     />
                        <TableColumn fx:id="colStatus"  text="STATUS"    />
                        <TableColumn fx:id="colActions" text="ACTIONS"   />
                    </columns>
                </TableView>
            </VBox>
        </Tab>

    </TabPane>
</VBox>
