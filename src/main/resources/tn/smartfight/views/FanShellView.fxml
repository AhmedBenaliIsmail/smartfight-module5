<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>
<BorderPane xmlns:fx="http://javafx.com/fxml/1" xmlns="http://javafx.com/javafx/21"
            fx:controller="tn.smartfight.controllers.FanShellController"
            stylesheets="@../styles/smartfight.css">

    <left>
        <VBox fx:id="sidebar" styleClass="sidebar" spacing="0" minWidth="64" prefWidth="256" maxWidth="256">

            <!-- Branding -->
            <VBox fx:id="vboxBrand" style="-fx-background-color: transparent; -fx-padding: 24 16 16 20;" spacing="0">
                <Label fx:id="lblBrand" text="SMARTFIGHT" styleClass="app-title"
                       style="-fx-font-style: italic; -fx-font-weight: 900; -fx-font-size: 20px;"/>
                <Label fx:id="lblSubtitle" text="FAN PORTAL" styleClass="app-subtitle"
                       style="-fx-letter-spacing: 2px;"/>
            </VBox>

            <!-- User Info -->
            <VBox fx:id="vboxUser"
                  style="-fx-padding: 4 16 24 20; -fx-border-color: transparent transparent #27272a transparent; -fx-border-width: 0 0 1 0;"
                  spacing="3">
                <Label fx:id="lblSignedIn" text="SIGNED IN AS"
                       style="-fx-font-size: 9px; -fx-text-fill: #a1a1aa; -fx-font-weight: bold;"/>
                <Label fx:id="lblFanName" styleClass="user-label" text="Fan"/>
            </VBox>

            <!-- Navigation -->
            <VBox style="-fx-padding: 16 8 0 8;" spacing="4" VBox.vgrow="ALWAYS">
                <Button fx:id="btnBlog"          text="NEWS"          styleClass="nav-btn" onAction="#onBlogClicked"          maxWidth="Infinity"/>
                <Button fx:id="btnBookings"      text="BOOKINGS"      styleClass="nav-btn" onAction="#onBookingsClicked"      maxWidth="Infinity"/>
                <Button fx:id="btnPredictions"   text="PREDICTIONS"   styleClass="nav-btn" onAction="#onPredictionsClicked"   maxWidth="Infinity"/>
                <Button fx:id="btnReactions"     text="REACTIONS"     styleClass="nav-btn" onAction="#onReactionsClicked"     maxWidth="Infinity"/>
                <HBox fx:id="hboxNotif" alignment="CENTER_LEFT" spacing="6" style="-fx-padding: 0;">
                    <Button fx:id="btnNotifications" text="NOTIFICATIONS" styleClass="nav-btn"
                            onAction="#onNotificationsClicked" maxWidth="Infinity" HBox.hgrow="ALWAYS"/>
                    <Label fx:id="lblUnreadCount" styleClass="unread-badge" text="" visible="false" managed="false"/>
                </HBox>
                <Region VBox.vgrow="ALWAYS"/>
            </VBox>

            <!-- Divider -->
            <Region style="-fx-background-color: #27272a; -fx-pref-height: 1; -fx-min-height: 1;"/>

            <!-- Bottom actions -->
            <VBox style="-fx-padding: 12 8 8 8;" spacing="4">
                <Button fx:id="btnSwitchRole" text="SWITCH ROLE" styleClass="nav-btn" onAction="#onSwitchRoleClicked"
                        maxWidth="Infinity" style="-fx-text-fill: #a1a1aa; -fx-font-size: 11px;"/>
                <Button fx:id="btnCollapse" text="‹" onAction="#onToggleSidebar" maxWidth="Infinity"
                        style="-fx-background-color: transparent; -fx-text-fill: #52525b; -fx-font-size: 16px;
                               -fx-font-weight: bold; -fx-cursor: hand; -fx-padding: 6 0; -fx-border-color: transparent;"/>
            </VBox>
        </VBox>
    </left>

    <center>
        <StackPane fx:id="contentArea" styleClass="content-area" BorderPane.alignment="CENTER"/>
    </center>
</BorderPane>
