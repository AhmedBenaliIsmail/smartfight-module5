<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>
<BorderPane xmlns:fx="http://javafx.com/fxml/1" xmlns="http://javafx.com/javafx/21"
            fx:controller="tn.smartfight.controllers.BlogReadController"
            stylesheets="@../styles/smartfight.css"
            style="-fx-background-color: #09090b;">

    <!-- TOP: Header with Title and Filters -->
    <top>
        <VBox style="-fx-padding: 32 40 24 40;" spacing="16">
            <HBox alignment="BOTTOM_LEFT" spacing="20">
                <VBox spacing="4" HBox.hgrow="ALWAYS">
                    <HBox alignment="BASELINE_LEFT" spacing="8">
                        <Label text="COMBAT" style="-fx-font-size: 48px; -fx-font-weight: 900; -fx-font-style: italic; -fx-text-fill: #fafafa;"/>
                        <Label text="NEWS" style="-fx-font-size: 48px; -fx-font-weight: 900; -fx-font-style: italic; -fx-text-fill: #dc2626;"/>
                    </HBox>
                    <Label text="LATEST UPDATES, BREAKDOWNS, AND EXCLUSIVE INTERVIEWS"
                           style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #a1a1aa;"/>
                </VBox>

                <!-- Filters -->
                <HBox spacing="12" alignment="CENTER_RIGHT">
                    <ComboBox fx:id="cbCategory" styleClass="dark-combo" prefWidth="180" promptText="ALL NEWS"
                              onAction="#onCategoryChanged"
                              style="-fx-background-radius: 9999; -fx-border-radius: 9999; -fx-font-weight: bold; -fx-text-fill: #fafafa;"/>
                    <TextField fx:id="txtSearch" styleClass="text-field" promptText="Search news..." prefWidth="200"
                               onAction="#onSearch"
                               style="-fx-background-radius: 9999; -fx-border-radius: 9999;"/>
                    <Button text="GO" styleClass="btn-primary" onAction="#onSearch"
                            style="-fx-padding: 10 24; -fx-background-radius: 9999;"/>
                </HBox>
            </HBox>

            <!-- Section header -->
            <HBox alignment="BASELINE_LEFT"
                  style="-fx-border-color: transparent transparent #dc2626 transparent; -fx-border-width: 0 0 2 0; -fx-padding: 8 0;">
                <Label text="LATEST STORIES" style="-fx-font-size: 14px; -fx-font-weight: 900; -fx-font-style: italic; -fx-text-fill: #fafafa;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label text="SORT BY: NEWEST" style="-fx-font-size: 10px; -fx-font-weight: bold; -fx-text-fill: #71717a;"/>
            </HBox>
        </VBox>
    </top>

    <!-- CENTER: News Grid -->
    <center>
        <ScrollPane fx:id="scrollPane" fitToWidth="true"
                    style="-fx-background-color: transparent; -fx-background: transparent;"
                    hbarPolicy="NEVER" vbarPolicy="AS_NEEDED">
            <VBox fx:id="newsGrid" spacing="20"
                  style="-fx-background-color: transparent; -fx-padding: 0 40 40 40;"/>
        </ScrollPane>
    </center>

</BorderPane>
